# NOVA AI Platform - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env with real credentials

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Groq (free tier, no credit card): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Default model
GROQ_MODEL=llama-3.1-8b-instant

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for uploading fine-tuned model to HF Hub
HF_TOKEN=your_huggingface_token_here
HF_USERNAME=your_hf_username

# ── Weights & Biases ─────────────────────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=nova-brand-voice
WANDB_ENTITY=your_wandb_username

# ── Fine-tuned Model ──────────────────────────────────────────────────────────
# After Task 4, set the HF Hub path
FINETUNED_MODEL_PATH=your_hf_username/nova-brand-voice-tinyllama

# ── Paths (Colab-friendly) ────────────────────────────────────────────────────
MOCK_DB_PATH=nova_mock_db.json
CHROMA_DB_PATH=./chroma_db
AUDIT_LOG_PATH=audit_log.jsonl
NOVA_TRACES_PATH=nova_traces.json
